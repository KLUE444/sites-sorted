          </div>

          <div class="quick-points">
            <div class="quick-point">
              <strong>Classic consoles</strong>
              <span>90s games and old-school favourites</span>
            </div>
            <div class="quick-point">
              <strong>Modern games</strong>
              <span>Now added due to demand</span>
            </div>
            <div class="quick-point">
              <strong>Party ready</strong>
              <span>Birthdays, schools, fairs and events</span>
            </div>
          </div>
        </div>

        <div class="hero-visual">

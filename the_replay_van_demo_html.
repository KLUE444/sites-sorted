          </article>

          <article class="service-card">
            <div class="icon">🎧</div>
            <h3>Music Challenges</h3>
            <p>
              Interactive music-based games and challenges to keep the energy high.
            </p>
          </article>

          <article class="service-card">
            <div class="icon">🎪</div>
            <h3>Schools, Fairs & Events</h3>
            <p>
              A brilliant crowd-pleaser for community events, school visits and festivals.
            </p>
          </article>

        </div>

      </div>
    </section>

    <section id="games">
      <div class="container showcase">


<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>The Replay Van | 90s Retro Gaming Party Van</title>
  <meta name="description" content="The Replay Van brings retro gaming, 90s nostalgia, music challenges, movies and modern gaming to parties, events, fairs and school visits across Lincolnshire and surrounding areas.">

  <style>
    :root {
      --bg: #050008;
      --surface: #120018;
      --surface2: #1c0628;
      --pink: #ff2fb3;
      --cyan: #00d9ff;
      --yellow: #ffe600;
      --purple: #8b2cff;
      --green: #83ff00;
      --white: #ffffff;
      --muted: #d7c9e8;
      --radius: 26px;
      --shadow: 0 0 35px rgba(255, 47, 179, 0.32);
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: Arial, Helvetica, sans-serif;
      background:
        radial-gradient(circle at top left, rgba(255,47,179,.25), transparent 30%),
        radial-gradient(circle at top right, rgba(0,217,255,.22), transparent 32%),
        radial-gradient(circle at bottom, rgba(139,44,255,.28), transparent 35%),
        var(--bg);
      color: var(--white);
      line-height: 1.6;
      overflow-x: hidden;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    img {
      width: 100%;
      display: block;
    }

    .container {
      width: min(1160px, 92%);
      margin: 0 auto;
    }

    header {
      padding: 22px 0;
      position: sticky;
      top: 0;
      z-index: 10;
      background: rgba(5,0,8,.86);
      backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(255,255,255,.12);
    }

    .nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
    }

    .logo {
      font-weight: 900;
      font-size: 1.4rem;
      letter-spacing: .5px;
      color: var(--yellow);
      text-shadow: 0 0 14px rgba(255,230,0,.75);
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 22px;
      color: var(--muted);
      font-weight: 800;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 14px 24px;
      border-radius: 999px;
      background: linear-gradient(135deg, var(--pink), var(--purple), var(--cyan));
      color: var(--white);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: .5px;
      box-shadow: 0 0 24px rgba(255,47,179,.55);
      border: 2px solid rgba(255,255,255,.25);
      transition: .25s ease;
    }

    .btn:hover {
      transform: translateY(-3px) scale(1.02);
      box-shadow: 0 0 35px rgba(0,217,255,.65);
    }

    .btn.secondary {
      background: transparent;
      color: var(--yellow);
      border: 2px solid var(--yellow);
      box-shadow: 0 0 18px rgba(255,230,0,.35);
    }

    .hero {
      padding: 80px 0 65px;
      position: relative;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.05fr .95fr;
      gap: 46px;
      align-items: center;
    }

    .eyebrow {
      display: inline-block;
      margin-bottom: 18px;
      padding: 9px 16px;
      border-radius: 999px;
      background: rgba(0,217,255,.12);
      border: 1px solid rgba(0,217,255,.7);
      color: var(--cyan);
      font-weight: 900;
      text-transform: uppercase;
      box-shadow: 0 0 18px rgba(0,217,255,.35);
    }

    h1 {
      font-size: clamp(3rem, 7vw, 6.5rem);
      line-height: .9;
      letter-spacing: -3px;
      margin-bottom: 24px;
      text-transform: uppercase;
    }

    .gradient-text {
      background: linear-gradient(90deg, var(--yellow), var(--pink), var(--cyan));
      -webkit-background-clip: text;
      color: transparent;
      text-shadow: none;
    }

    .hero p {
      color: var(--muted);
      font-size: 1.18rem;
      max-width: 650px;
      margin-bottom: 30px;
    }

    .hero-actions {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
    }

    .hero-card {
      background: rgba(18,0,24,.82);
      border: 2px solid rgba(255,47,179,.5);
      border-radius: var(--radius);
      padding: 16px;
      box-shadow: var(--shadow);
      transform: rotate(1deg);
    }

    .hero-card img {
      border-radius: 20px;
      border: 1px solid rgba(255,255,255,.18);
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
      margin-top: 34px;
    }

    .stat {
      background: rgba(255,255,255,.06);
      border: 1px solid rgba(255,255,255,.12);
      border-radius: 18px;
      padding: 18px;
      text-align: center;
    }

    .stat strong {
      display: block;
      font-size: 1.8rem;
      color: var(--yellow);
    }

    section {
      padding: 72px 0;
    }

    .section-title {
      text-align: center;
      max-width: 760px;
      margin: 0 auto 40px;
    }

    .section-title h2 {
      font-size: clamp(2.2rem, 4vw, 4rem);
      line-height: .95;
      margin-bottom: 16px;
      text-transform: uppercase;
    }

    .section-title p {
      color: var(--muted);
      font-size: 1.08rem;
    }

    .cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
    }

    .card {
      background: linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.035));
      border: 1px solid rgba(255,255,255,.16);
      border-radius: var(--radius);
      padding: 28px;
      box-shadow: 0 0 24px rgba(0,0,0,.22);
    }

    .card:nth-child(1) { border-color: rgba(255,47,179,.55); }
    .card:nth-child(2) { border-color: rgba(0,217,255,.55); }
    .card:nth-child(3) { border-color: rgba(255,230,0,.55); }
    .card:nth-child(4) { border-color: rgba(131,255,0,.55); }
    .card:nth-child(5) { border-color: rgba(139,44,255,.75); }
    .card:nth-child(6) { border-color: rgba(255,47,179,.55); }

    .icon {
      font-size: 2.2rem;
      margin-bottom: 14px;
    }

    .card h3 {
      font-size: 1.35rem;
      margin-bottom: 10px;
      color: var(--yellow);
    }

    .card p {
      color: var(--muted);
    }

    .split {
      display: grid;
      grid-template-columns: .9fr 1.1fr;
      gap: 34px;
      align-items: center;
    }

    .image-panel {
      background: rgba(255,255,255,.06);
      border-radius: var(--radius);
      padding: 14px;
      border: 1px solid rgba(255,255,255,.16);
      box-shadow: var(--shadow);
    }

    .image-panel img {
      border-radius: 20px;
    }

    .feature-list {
      display: grid;
      gap: 16px;
    }

    .feature {
      padding: 18px 20px;
      border-radius: 18px;
      background: rgba(255,255,255,.06);
      border-left: 5px solid var(--pink);
      color: var(--muted);
    }

    .feature strong {
      color: var(--white);
    }

    .reviews {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 22px;
    }

    .review {
      background: rgba(255,255,255,.08);
      border: 1px solid rgba(255,47,179,.35);
      border-radius: var(--radius);
      padding: 28px;
      box-shadow: 0 0 22px rgba(255,47,179,.16);
    }

    .stars {
      color: var(--yellow);
      font-size: 1.2rem;
      margin-bottom: 12px;
    }

    .review p {
      color: var(--muted);
      font-size: 1.05rem;
    }

    .review strong {
      display: block;
      margin-top: 16px;
      color: var(--cyan);
    }

    .locations {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 12px;
      margin-top: 24px;
    }

    .pill {
      padding: 10px 16px;
      border-radius: 999px;
      background: rgba(255,255,255,.08);
      border: 1px solid rgba(0,217,255,.35);
      color: var(--muted);
      font-weight: 800;
    }

    .cta {
      text-align: center;
      background:
        linear-gradient(135deg, rgba(255,47,179,.26), rgba(0,217,255,.18)),
        rgba(255,255,255,.06);
      border: 2px solid rgba(255,255,255,.16);
      border-radius: 36px;
      padding: 54px 28px;
      box-shadow: var(--shadow);
    }

    .cta h2 {
      font-size: clamp(2.4rem, 5vw, 4.6rem);
      line-height: .95;
      margin-bottom: 16px;
      text-transform: uppercase;
    }

    .cta p {
      color: var(--muted);
      max-width: 680px;
      margin: 0 auto 28px;
      font-size: 1.1rem;
    }

    footer {
      padding: 34px 0;
      text-align: center;
      color: var(--muted);
      border-top: 1px solid rgba(255,255,255,.12);
    }

    @media (max-width: 860px) {
      .hero-grid,
      .split,
      .cards,
      .reviews {
        grid-template-columns: 1fr;
      }

      .nav-links {
        display: none;
      }

      .stats {
        grid-template-columns: 1fr;
      }

      h1 {
        letter-spacing: -2px;
      }
    }
  </style>
</head>


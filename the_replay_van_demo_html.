<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>The Replay Van | Retro Gaming Party Van Lincolnshire</title>
  <meta name="description" content="The Replay Van brings retro gaming, modern games, music challenges and 90s nostalgia to birthday parties, schools, fairs and events across Lincolnshire." />

  <style>
    :root {
      --black: #050308;
      --ink: #0d0714;
      --panel: #13091f;
      --panel2: #1d0c31;
      --white: #ffffff;
      --soft: #d9c7ef;
      --pink: #ff2fac;
      --cyan: #00d9ff;
      --yellow: #ffe600;
      --purple: #8a35ff;
      --blue: #285bff;
      --green: #85ff39;
      --radius: 28px;
      --shadow: 0 25px 80px rgba(0,0,0,.45);
      --glow-pink: 0 0 35px rgba(255,47,172,.42);
      --glow-cyan: 0 0 35px rgba(0,217,255,.38);
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: Arial, Helvetica, sans-serif;
      background:
        radial-gradient(circle at 10% 10%, rgba(255,47,172,.22), transparent 28%),
        radial-gradient(circle at 90% 5%, rgba(0,217,255,.2), transparent 30%),
        radial-gradient(circle at 50% 100%, rgba(138,53,255,.28), transparent 35%),
        var(--black);
      color: var(--white);
      line-height: 1.6;
      overflow-x: hidden;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    img {
      width: 100%;
      display: block;
    }

    .container {
      width: min(1180px, 92%);
      margin: 0 auto;
    }

    .topbar {
      background: linear-gradient(90deg, var(--pink), var(--purple), var(--cyan));
      color: white;
      text-align: center;
      padding: 9px 16px;
      font-weight: 900;
      font-size: .86rem;
      letter-spacing: .08em;
      text-transform: uppercase;
    }

    header {
      position: sticky;
      top: 0;
      z-index: 20;
      background: rgba(5,3,8,.82);
      backdrop-filter: blur(18px);
      border-bottom: 1px solid rgba(255,255,255,.12);
    }

    .nav {
      height: 78px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 22px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 950;
      letter-spacing: -.04em;
      font-size: 1.35rem;
    }

    .brand-mark {
      width: 42px;
      height: 42px;
      border-radius: 14px;
      display: grid;
      place-items: center;
      background: linear-gradient(135deg, var(--yellow), var(--pink), var(--cyan));
      box-shadow: var(--glow-pink);
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 26px;
      color: var(--soft);
      font-size: .92rem;
      font-weight: 800;
    }

    .nav-links a:hover {
      color: var(--yellow);
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 9px;
      padding: 14px 22px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,.18);
      background: linear-gradient(135deg, var(--pink), var(--purple), var(--cyan));
      color: var(--white);
      font-weight: 950;
      text-transform: uppercase;
      letter-spacing: .04em;
      font-size: .88rem;
      box-shadow: var(--glow-pink);
      transition: .25s ease;
      white-space: nowrap;
    }

    .btn:hover {
      transform: translateY(-3px);
      box-shadow: var(--glow-cyan);
    }

    .btn.alt {
      background: rgba(255,255,255,.06);
      color: var(--yellow);
      border-color: rgba(255,230,0,.45);
      box-shadow: 0 0 24px rgba(255,230,0,.18);
    }

    .hero {
      padding: 76px 0 70px;
      position: relative;
    }

    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
      background-size: 46px 46px;
      mask-image: linear-gradient(to bottom, black, transparent 75%);
      pointer-events: none;
    }

    .hero-grid {
      position: relative;
      display: grid;
      grid-template-columns: 1fr .92fr;
      gap: 52px;
      align-items: center;
    }

    .kicker {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 9px 15px;
      border-radius: 999px;
      background: rgba(0,217,255,.09);
      border: 1px solid rgba(0,217,255,.5);
      color: var(--cyan);
      font-weight: 950;
      text-transform: uppercase;
      letter-spacing: .08em;
      font-size: .78rem;
      margin-bottom: 22px;
      box-shadow: var(--glow-cyan);
    }

    h1 {
      max-width: 720px;
      font-size: clamp(3.5rem, 8vw, 7.6rem);
      line-height: .84;
      letter-spacing: -.075em;
      text-transform: uppercase;
      margin-bottom: 24px;
    }

    .neon {
      background: linear-gradient(90deg, var(--yellow), var(--pink), var(--cyan));
      -webkit-background-clip: text;
      color: transparent;
    }

    .hero-copy {
      color: var(--soft);
      font-size: 1.18rem;
      max-width: 620px;
      margin-bottom: 30px;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin-bottom: 34px;
    }

    .quick-points {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      max-width: 720px;
    }

    .quick-point {
      padding: 16px;
      border-radius: 20px;
      background: rgba(255,255,255,.065);
      border: 1px solid rgba(255,255,255,.12);
    }

    .quick-point strong {
      display: block;
      color: var(--yellow);
      font-size: 1.05rem;
      margin-bottom: 2px;
    }

    .quick-point span {
      color: var(--soft);
      font-size: .92rem;
    }

    .hero-visual {
      position: relative;
    }

    .visual-card {
      position: relative;
      padding: 14px;
      border-radius: 34px;
      background: linear-gradient(135deg, rgba(255,47,172,.75), rgba(0,217,255,.65));
      box-shadow: var(--shadow), var(--glow-pink);
      transform: rotate(1.5deg);
    }

    .visual-card img {
      border-radius: 24px;
      border: 2px solid rgba(255,255,255,.18);
      background: #000;
    }

    .floating-badge {
      position: absolute;
      left: -24px;
      bottom: 28px;
      max-width: 210px;
      padding: 18px;
      border-radius: 22px;
      background: rgba(5,3,8,.92);
      border: 1px solid rgba(255,230,0,.55);
      box-shadow: 0 0 30px rgba(255,230,0,.22);
      transform: rotate(-3deg);
    }

    .floating-badge strong {
      color: var(--yellow);
      display: block;
      font-size: 1.1rem;
      line-height: 1.1;
      margin-bottom: 5px;
    }

    .floating-badge span {
      color: var(--soft);
      font-size: .9rem;
    }

    section {
      padding: 76px 0;
    }

    .section-head {
      max-width: 760px;
      margin-bottom: 38px;
    }

    .section-head.center {
      text-align: center;
      margin: 0 auto 42px;
    }

    .section-head .label {
      color: var(--cyan);
      font-weight: 950;
      letter-spacing: .08em;
      text-transform: uppercase;
      font-size: .8rem;
      margin-bottom: 10px;
    }

    .section-head h2 {
      font-size: clamp(2.3rem, 5vw, 4.6rem);
      line-height: .9;
      letter-spacing: -.06em;
      text-transform: uppercase;
      margin-bottom: 16px;
    }

    .section-head p {
      color: var(--soft);
      font-size: 1.08rem;
    }

    .service-grid {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 18px;
    }

    .service-card {
      grid-column: span 2;
      min-height: 240px;
      padding: 26px;
      border-radius: var(--radius);
      background:
        linear-gradient(180deg, rgba(255,255,255,.085), rgba(255,255,255,.035));
      border: 1px solid rgba(255,255,255,.14);
      box-shadow: 0 18px 60px rgba(0,0,0,.28);
      position: relative;
      overflow: hidden;
    }

    .service-card.large {
      grid-column: span 3;
    }

    .service-card::after {
      content: "";
      position: absolute;
      width: 160px;
      height: 160px;
      right: -65px;
      bottom: -65px;
      border-radius: 999px;
      background: rgba(255,47,172,.22);
      filter: blur(6px);
    }

    .service-card:nth-child(2)::after,
    .service-card:nth-child(5)::after {
      background: rgba(0,217,255,.22);
    }

    .service-card:nth-child(3)::after {
      background: rgba(255,230,0,.2);
    }

    .service-card .icon {
      font-size: 2.4rem;
      margin-bottom: 16px;
    }

    .service-card h3 {
      font-size: 1.45rem;
      line-height: 1.1;
      margin-bottom: 12px;
      color: var(--white);
    }

    .service-card p {
      color: var(--soft);
      position: relative;
      z-index: 2;
    }

    .showcase {
      display: grid;
      grid-template-columns: .95fr 1.05fr;
      gap: 42px;
      align-items: center;
    }

    .image-frame {
      padding: 12px;
      border-radius: 34px;
      background: linear-gradient(135deg, rgba(255,47,172,.7), rgba(0,217,255,.55), rgba(255,230,0,.5));
      box-shadow: var(--shadow);
    }

    .image-frame img {
      border-radius: 24px;
      background: #000;
    }

    .feature-stack {
      display: grid;
      gap: 14px;
    }

    .feature-row {
      display: grid;
      grid-template-columns: 58px 1fr;
      gap: 16px;
      align-items: start;
      padding: 18px;
      border-radius: 22px;
      background: rgba(255,255,255,.065);
      border: 1px solid rgba(255,255,255,.12);
    }

    .feature-row .num {
      width: 48px;
      height: 48px;
      border-radius: 16px;
      display: grid;
      place-items: center;
      background: rgba(255,47,172,.18);
      border: 1px solid rgba(255,47,172,.45);
      color: var(--yellow);
      font-weight: 950;
    }

    .feature-row h3 {
      font-size: 1.15rem;
      margin-bottom: 3px;
    }

    .feature-row p {
      color: var(--soft);
    }

    .game-strip {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-top: 28px;
    }

    .game-box {
      padding: 18px;
      border-radius: 20px;
      background: rgba(255,255,255,.06);
      border: 1px solid rgba(0,217,255,.25);
    }

    .game-box strong {
      color: var(--cyan);
      display: block;
      margin-bottom: 8px;
      text-transform: uppercase;
      font-size: .86rem;
      letter-spacing: .07em;
    }

    .game-box p {
      color: var(--soft);
      font-size: .95rem;
    }

    .reviews-wrap {
      display: grid;
      grid-template-columns: 1.05fr .95fr;
      gap: 28px;
      align-items: stretch;
    }

    .review-main {
      padding: 34px;
      border-radius: 34px;
      background: linear-gradient(180deg, rgba(255,255,255,.09), rgba(255,255,255,.04));
      border: 1px solid rgba(255,47,172,.45);
      box-shadow: var(--glow-pink);
    }

    .stars {
      color: var(--yellow);
      font-size: 1.25rem;
      margin-bottom: 18px;
      letter-spacing: .05em;
    }

    .review-main blockquote {
      font-size: 1.18rem;
      color: var(--white);
      line-height: 1.65;
      margin-bottom: 22px;
    }

    .review-main cite {
      color: var(--cyan);
      font-style: normal;
      font-weight: 950;
    }

    .review-side {
      display: grid;
      gap: 18px;
    }

    .mini-review {
      padding: 24px;
      border-radius: 26px;
      background: rgba(255,255,255,.06);
      border: 1px solid rgba(255,255,255,.13);
    }

    .mini-review strong {
      color: var(--yellow);
      display: block;
      margin-bottom: 8px;
    }

    .mini-review p {
      color: var(--soft);
    }

    .locations {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 12px;
      margin-top: 24px;
    }

    .pill {
      padding: 11px 16px;
      border-radius: 999px;
      background: rgba(255,255,255,.07);
      border: 1px solid rgba(255,255,255,.14);
      color: var(--soft);
      font-weight: 850;
    }

    .contact-panel {
      position: relative;
      overflow: hidden;
      padding: 54px;
      border-radius: 40px;
      background:
        linear-gradient(135deg, rgba(255,47,172,.25), rgba(0,217,255,.18)),
        rgba(255,255,255,.07);
      border: 1px solid rgba(255,255,255,.16);
      box-shadow: var(--shadow), var(--glow-cyan);
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 28px;
      align-items: center;
    }

    .contact-panel::after {
      content: "▶";
      position: absolute;
      right: 34px;
      top: -40px;
      font-size: 12rem;
      color: rgba(255,255,255,.04);
      transform: rotate(12deg);
    }

    .contact-panel h2 {
      font-size: clamp(2.6rem, 5vw, 5rem);
      line-height: .9;
      letter-spacing: -.065em;
      text-transform: uppercase;
      margin-bottom: 15px;
    }

    .contact-panel p {
      color: var(--soft);
      max-width: 680px;
      font-size: 1.08rem;
    }

    footer {
      padding: 34px 0;
      color: var(--soft);
      border-top: 1px solid rgba(255,255,255,.12);
      text-align: center;
      font-size: .95rem;
    }

    @media (max-width: 950px) {
      .hero-grid,
      .showcase,
      .reviews-wrap,
      .contact-panel {
        grid-template-columns: 1fr;
      }

      .quick-points,
      .game-strip {
        grid-template-columns: 1fr;
      }

      .service-card,
      .service-card.large {
        grid-column: span 6;
      }

      .nav-links {
        display: none;
      }

      .floating-badge {
        position: static;
        margin-top: 16px;
        max-width: none;
        transform: none;
      }
    }
  </style>
</head>

<body>

  <div class="topbar">
    Limited dates available — message now to get booked in
  </div>

  <header>
    <div class="container nav">
      <a href="#" class="brand">
